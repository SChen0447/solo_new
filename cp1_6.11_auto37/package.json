{
  "name": "collaborative-whiteboard",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "tsx watch server/index.ts",
    "client": "vite",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "uuid": "^9.0.1",
    "cors": "^2.8.5",
    "msgpackr": "^1.10.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.8",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "@vitejs/plugin-react": "^4.2.1",
    "tsx": "^4.7.1",
    "concurrently": "^8.2.2"
  }
}
