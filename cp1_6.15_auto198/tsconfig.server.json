{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "outDir": "./dist-server",
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": ["server"],
  "exclude": ["node_modules", "src", "dist"]
}
