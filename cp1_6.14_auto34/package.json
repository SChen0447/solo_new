{
  "name": "assignment-grading-system",
  "version": "1.0.0",
  "description": "在线教育平台作业批注与评分管理系统",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
