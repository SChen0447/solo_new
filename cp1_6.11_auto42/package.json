{
  "name": "music-collab-studio",
  "version": "1.0.0",
  "description": "远程协作音乐创作与录制平台",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "ts-node --esm server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "fluent-ffmpeg": "^2.1.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/uuid": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/fluent-ffmpeg": "^2.1.21",
    "@types/ws": "^8.5.5",
    "@types/node": "^20.4.2",
    "typescript": "^5.1.6",
    "vite": "^4.4.5",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.0"
  }
}
