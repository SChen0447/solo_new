{
  "name": "virtual-gallery-walk",
  "version": "1.0.0",
  "description": "虚拟画廊漫步 - 2.5D虚拟艺术展览Web应用",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
