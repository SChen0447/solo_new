{
  "name": "eco-simulator",
  "version": "1.0.0",
  "description": "Ecosystem evolution and ecological balance simulation tool for game designers",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
