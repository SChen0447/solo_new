{
  "name": "workspace-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5",
    "axios": "^1.7.7",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "better-sqlite3": "^11.3.0",
    "uuid": "^10.0.0",
    "qrcode": "^1.5.4",
    "lucide-react": "^0.445.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.5",
    "@types/uuid": "^10.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.6",
    "tsx": "^4.19.1",
    "concurrently": "^9.0.1"
  }
}
