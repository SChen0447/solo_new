{
  "name": "skill-tree-designer",
  "version": "1.0.0",
  "description": "Skill tree designer for game developers",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node --project tsconfig.server.json server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.2",
    "uuid": "^9.0.1",
    "recharts": "^2.10.3",
    "lodash": "^4.17.21",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/uuid": "^9.0.7",
    "@types/lodash": "^4.14.202",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.9.4",
    "typescript": "^5.3.2",
    "vite": "^5.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.2"
  }
}
