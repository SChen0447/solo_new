{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist-server",
    "rootDir": "./server",
    "baseUrl": ".",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["server/**/*.ts"]
}
