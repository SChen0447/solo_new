  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist-server",
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": ["src/server/**/*.ts", "src/client/quizEngine.ts"]
}
