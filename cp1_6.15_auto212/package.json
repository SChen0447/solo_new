{
  "name": "drifting-bookshelf",
  "version": "1.0.0",
  "description": "流浪书架 - 虚拟街头书架空间，让闲置书籍在城市中漂流",
  "scripts": {
    "dev": "vite",
    "server": "ts-node --esm server/server.ts",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "zustand": "^4.5.5",
    "axios": "^1.7.7",
    "react-router-dom": "^6.26.2",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "better-sqlite3": "^11.3.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "concurrently": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.5.4",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.5",
    "ts-node": "^10.9.2"
  }
}
