{
  "name": "portfolio-platform",
  "version": "1.0.0",
  "description": "Personal portfolio and project showcase platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node --project tsconfig.node.json server.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "init-db": "ts-node --project tsconfig.node.json db/init.ts"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "better-sqlite3": "^9.4.3",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.9",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.11.19",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "@vitejs/plugin-react": "^4.2.1",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2",
    "react-router-dom": "^6.22.1",
    "@types/react-router-dom": "^5.3.3"
  }
}
