    "zustand": "^4.4.7",
    "axios": "^1.6.2",
    "react-router-dom": "^6.20.1"
  },
  "devDependencies": {
    "typescript": "^5.3.2",
    "@types/react": "^18.2.41",
    "@types/react-dom": "^18.2.17",
    "vite": "^5.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2"
  }
}
